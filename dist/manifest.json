{
  "manifest_version": 3,
  "name": "Relay",
  "description": "Realtime stream translation and voiceover.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Relay"
  },
  "background": {
    "service_worker": "assets/serviceWorker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"]
}
